<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KioskBrowser" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorSecondaryVariant">@color/colorSecondaryVariant</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <item name="android:statusBarColor">@color/kiosk_background</item>
        <item name="android:windowBackground">@color/kiosk_background</item>
    </style>
    <style name="Theme.KioskBrowser.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:statusBarColor">@color/kiosk_background</item>
        <item name="android:navigationBarColor">@color/kiosk_background</item>
    </style>
</resources>
