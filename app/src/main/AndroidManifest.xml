<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml
    Enterprise Kiosk Browser

    Key enterprise decisions documented inline.
-->
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.enterprise.kioskbrowser">

    <!-- ======================================================================
         PERMISSIONS
         ====================================================================== -->

    <!-- Core networking -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Required so WebView can evaluate the network state for cache policy -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
        WAKE_LOCK keeps the screen on during active data-entry sessions.
        Pair with WindowManager.LayoutParams.FLAG_KEEP_SCREEN_ON in Activity
        or use an explicit WakeLock if the session timer is managed server-side.
    -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!--
        RECEIVE_BOOT_COMPLETED enables auto-launch on device restart —
        critical for unattended kiosk deployments.
    -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!--
        REQUEST_INSTALL_PACKAGES is intentionally OMITTED — kiosk devices
        must not allow sideloading. MDM handles APK distribution.
    -->

    <!-- ======================================================================
         APPLICATION
         ====================================================================== -->
    <application
        android:name=".KioskApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KioskBrowser"
        tools:targetApi="31">

        <!-- ==================================================================
             MAIN ACTIVITY
             ================================================================== -->
        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|keyboardHidden|keyboard|navigation|uiMode|fontScale|screenLayout"
            android:exported="true"
            android:immersive="true"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:stateNotNeeded="true"
            android:theme="@style/Theme.KioskBrowser.NoActionBar"
            android:windowSoftInputMode="adjustResize">

            <!-- Make this the launcher / home application for kiosk mode -->
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <!--
                    HOME + DEFAULT allow this app to be set as the device
                    launcher via MDM or Android's own "Select home app" dialog.
                    Remove if you do NOT want full home-replacement.
                -->
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

        </activity>

        <!-- ==================================================================
             BOOT RECEIVER — auto-launch after device restart
             ================================================================== -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <!-- HTC / some OEM boot action -->
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- ==================================================================
             PROVIDER — required by WebView internal file provider on API 24+
             ================================================================== -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
